# Frontend API base URL
VITE_API_URL=http://localhost:5000/api

# Backend server port
PORT=5000

# Option 1 (recommended): paste full MongoDB connection string from Atlas
# MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.h4xhkeu.mongodb.net/emart?retryWrites=true&w=majority&appName=Cluster0

# Option 2: provide Atlas parts separately (used when MONGODB_URI is not provided)
MONGODB_USERNAME=e-Mart
MONGODB_PASSWORD=your_db_password_here
MONGODB_CLUSTER=cluster0.h4xhkeu.mongodb.net
MONGODB_DB_NAME=emart
MONGODB_OPTIONS=retryWrites=true&w=majority&appName=Cluster0
