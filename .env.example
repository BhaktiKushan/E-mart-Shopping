# Frontend API base URL
VITE_API_URL=http://localhost:5000/api

# Backend server port
PORT=5000

# Option 1 (recommended): use your Atlas URI template
# mongodb+srv://Emart123:<db_password>@cluster0.h4xhkeu.mongodb.net/?appName=Cluster0
# Replace <db_password> with your real Atlas password.
MONGODB_URI=mongodb+srv://Emart123:<db_password>@cluster0.h4xhkeu.mongodb.net/?appName=Cluster0

# Option 2: split vars (used if MONGODB_URI is removed/commented)
MONGODB_USERNAME=Emart123
MONGODB_PASSWORD=your_db_password_here
MONGODB_CLUSTER=cluster0.h4xhkeu.mongodb.net
MONGODB_DB_NAME=emart
MONGODB_OPTIONS=retryWrites=true&w=majority&appName=Cluster0
